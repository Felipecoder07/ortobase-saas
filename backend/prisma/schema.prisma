datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  users     User[]
  patients  Patient[]
  dentists  Dentist[]
  appointments Appointment[]
  payments  Payment[]
  anamneses Anamnesis[]
  procedures Procedure[]
  treatmentPlans TreatmentPlan[]
  toothConditions ToothCondition[]
  attachments PatientAttachment[]
  odontogramLegends OdontogramLegend[]
}

model User {
  id                  String    @id @default(uuid())
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id])
  name                String
  email               String    @unique
  password            String
  role                String    @default("RECEPTIONIST") // ADMIN, RECEPTIONIST, DENTIST
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Patient {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  cpf           String
  dateOfBirth   DateTime
  phone         String
  email         String?
  address       String?
  clinicalNotes String?
  avatarUrl     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  appointments  Appointment[]
  anamnesis     Anamnesis?
  treatmentPlans TreatmentPlan[]
  toothConditions ToothCondition[]
  attachments    PatientAttachment[]

  @@unique([tenantId, cpf]) // CPF is unique within a tenant
}

model Dentist {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  cro         String
  specialties String?
  phone       String
  email       String?
  gender      String   @default("M") // M ou F
  avatarUrl   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  appointments Appointment[]
  treatmentPlans TreatmentPlan[]
}

model Appointment {
  id                 String   @id @default(uuid())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  patientId          String
  patient            Patient  @relation(fields: [patientId], references: [id])
  dentistId          String
  dentist            Dentist  @relation(fields: [dentistId], references: [id])
  date               DateTime
  durationInMinutes  Int
  serviceType        String
  price              Float    @default(0.0)
  status             String   @default("SCHEDULED") // SCHEDULED, CONFIRMED, CANCELED, COMPLETED, NO_SHOW
  cancellationReason String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  payment            Payment?
  procedures         Procedure[]
}

model Payment {
  id             String      @id @default(uuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  appointmentId  String      @unique
  appointment    Appointment @relation(fields: [appointmentId], references: [id])
  amount         Float
  method         String      // PIX, CREDIT_CARD, DEBIT_CARD, CASH
  status         String      @default("PENDING") // PENDING, PAID, REFUNDED
  discount       Float       @default(0)
  installments   Int         @default(1)
  refundReason   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Anamnesis {
  id                String   @id @default(uuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  patientId         String   @unique
  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  mainComplaint     String?
  allergies         String?
  medicationsInUse  String?
  chronicDiseases   String?
  previousSurgeries String?
  observations      String?
  signatureUrl      String?
  signedAt          DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Procedure {
  id                String   @id @default(uuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  name              String
  description       String?
  basePrice         Float
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  treatmentPlanItems TreatmentPlanItem[]
  appointments      Appointment[]
}

model TreatmentPlan {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  dentistId   String
  dentist     Dentist  @relation(fields: [dentistId], references: [id])
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  totalAmount Float    @default(0.0)
  discount    Float    @default(0.0)
  notes       String?
  signatureUrl String?
  signedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       TreatmentPlanItem[]
}

model TreatmentPlanItem {
  id              String   @id @default(uuid())
  treatmentPlanId String
  treatmentPlan   TreatmentPlan @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)
  procedureId     String
  procedure       Procedure     @relation(fields: [procedureId], references: [id])
  price           Float
  tooth           String?       // Opcional, para indicar dente
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ToothCondition {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  toothNumber String
  face        String   // V, L, P, M, D, O, I, ALL
  condition   String   // CARIES, RESTORED, EXTRACTED, IMPLANT, CROWN, ENDODONTICS, HEALTHY
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([patientId, toothNumber, face]) // Garante que a mesma face não tenha dois status duplicados
}

model PatientAttachment {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  filename    String
  fileUrl     String
  fileType    String   // image/jpeg, application/pdf, etc
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OdontogramLegend {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  color     String
  createdAt DateTime @default(now())

  @@unique([tenantId, name])
}
